---
import type { GetStaticPaths } from "astro";
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import styles from '../../styles/collections.css';

export const getStaticPaths = (() => {
    return [
        {params: {collections: 'cuento'}},
        {params: {collections: 'poema'}},
    ];
}) satisfies GetStaticPaths;

const { collections } = Astro.params;
const posts = (await getCollection(collections as 'cuento' | 'poema')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class={styles}>
			<section>
				<ul>
					{posts.map((post) => (
						<li>
							<a href={`/${collections}/${post.id}/`}>
								{post.data.heroImage && (
									<Image width={520} height={320} src={post.data.heroImage} alt="Ilustracion" />
								)}
								<h4 class="title">{post.data.title}</h4>
								<p class="date">
									<FormattedDate date={post.data.pubDate} />
								</p>
							</a>
							<p>{post.data.description}</p>
						</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
