---
import type { GetStaticPaths } from "astro";
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import '../../styles/collections.css';

export const getStaticPaths = (() => {
    return [
        {params: {collections: 'cuento'}},
        {params: {collections: 'poema'}},
    ];
}) satisfies GetStaticPaths;

const { collections } = Astro.params;
const posts = (await getCollection(collections as 'cuento' | 'poema')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="site-colecciones">
			<section class="lista-escritos-container">
				<ul class="grid-escritos">
					{posts.map((post) => (
						<li class="tarjeta-escrito">
							<a href={`/${collections}/${post.id}/`} class="enlace-tarjeta">
								{post.data.heroImage && (
									<div class="imagen-escrito">
										<Image width={520} height={320} src={post.data.heroImage} alt="Ilustracion" />
									</div>
								)}
								<div class="contenido-tarjeta">
									<p class="date">
										<FormattedDate date={post.data.pubDate} />
									</p>
									<h2 class="title">{post.data.title}</h2>
									<p class="descripcion">{post.data.description}</p>
									<span class="leer-mas">Leer &rarr;</span>
								</div>
							</a>
						</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
