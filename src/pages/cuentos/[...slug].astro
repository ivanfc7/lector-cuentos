---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import Publicacion from '../../layouts/publicacion.astro';

export async function getStaticPaths() {
	const posts = await getCollection('cuento');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}
type Props = CollectionEntry<'cuento'>;

const post = Astro.props;
const { Content } = await render(post);
---

<Publicacion {...post.data}>
	<Content />
</Publicacion>
